# ============================================
# T-Content Manager — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-here-change-me
ADMIN_EMAIL=solutions@tejiona.com
ADMIN_PASSWORD_HASH=  # Generated with bcrypt

# --- Database (Vercel Postgres) ---
DATABASE_URL=postgresql://user:pass@host:5432/t_content_manager
DIRECT_URL=postgresql://user:pass@host:5432/t_content_manager

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # $349 CAD/month
STRIPE_PRICE_GROWTH=price_...     # $699 CAD/month

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=TEJIONA AI Solutions <solutions@tejiona.com>

# --- AI (Google Gemini) ---
GEMINI_API_KEY=AIza...

# --- n8n (optional) ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/
N8N_API_KEY=

# --- Social Media APIs (for auto-publishing) ---
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
